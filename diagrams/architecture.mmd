---
config:
  flowchart:
    subGraphTitleMargin:
      bottom: 20
---

graph TD
    %% External Entity
    Client(["<span style='font-size:20px'><b>Client</b></span><br/>"]) 

    subgraph VRM_System ["<span style='font-size:20px'><b>VRM System</b></span><br/><br/>"]
        direction TB
        
        %% Entry Point
        VrmManager{VrmManager}:::gateNode
        
            subgraph MasterADC_subgraph ["<span style='font-size:20px'><b>VrmComponent</b></span><br/><br/>"]
                direction TB
                
                MasterADC["(Master) ADC"]:::adcParentNode
                WorkflowScheduler[WorkflowScheduler]:::adcParentNode
                VrmComponentManager_1[VrmComponentManager]:::adcParentNode

                subgraph AcI_subgraph_1 ["<span style='font-size:20px'><b>VrmComponent</b></span><br/><br/>"]
                    direction TB
                    AcI_1[AcI 1]:::aciNode
                    
                    %% RMS Instance 1
                    subgraph Rms_AcI_1 ["<span style='font-size:20px'><b>AdvanceReservationRms</b></span><br/><br/>"]
                        direction TB
                        RmsConnector_1[SlurmRms]:::rmsNode
                        subgraph Schedule_1 ["<span style='font-size:20px'><b>Schedule</b></span><br/><br/>"]
                            direction TB
                            SlottedNodeSchedule_1[SlottedNodeSchedule]:::scheduleNode
                            SlottedLinkSchedule_1[SlottedLinkSchedule]:::scheduleNode
                            NetworkTopology_1[NetworkTopology]:::scheduleNode
                        end
                    end
                end

                subgraph ADC_subgraph_1["<span style='font-size:20px'><b>VrmComponent</b></span><br/><br/>"]
                    direction TB
                    
                    ADC_1["(Child) ADC"]:::adcChildNode
                    VrmComponentManager_2[VrmComponentManager]:::adcChildNode
                
                    subgraph AcI_subgraph_2 ["<span style='font-size:20px'><b>VrmComponent</b></span><br/><br/>"]
                        direction TB
                        AcI_2[AcI 2]:::aciNode
                        %% RMS Instance 2
                        subgraph Rms_AcI_2 ["<span style='font-size:20px'><b>AdvanceReservationRms</b></span><br/><br/>"]
                            direction TB
                            RmsConnector_2[RmsNetworkSimulator]:::rmsNode
                            subgraph Schedule_2 ["<span style='font-size:20px'><b>Schedule</b></span><br/><br/>"]
                                direction TB
                                SlottedLinkSchedule_2[SlottedLinkSchedule]:::scheduleNode
                                NetworkTopology_2[NetworkTopology]:::scheduleNode
                            end
                        end
                    end 

                    subgraph AcI_subgraph_3 ["<span style='font-size:20px'><b>VrmComponent</b></span><br/><br/>"]
                        direction TB
                        AcI_3[AcI 3]:::aciNode
                        %% RMS Instance 3
                        subgraph Rms_AcI_3 ["<span style='font-size:20px'><b>AdvanceReservationRms</b></span><br/><br/>"]
                            direction TB
                            RmsConnector_3[RmsNodeSimulator]:::rmsNode
                            subgraph Schedule_3 ["<span style='font-size:20px'><b>Schedule</b></span><br/><br/>"]
                                direction TB
                                SlottedNodeSchedule_3[SlottedNodeSchedule]:::scheduleNode
                            end
                        end
                    end 
                end
            end
        end

    %% --- Connections ---

    %% Client Entry
    Client -- "Submits JSON Workflow" --- VrmManager
    VrmManager -- "Manages Reservation Life-Cycle" --- MasterADC
    
    %% MasterADCInternal
    MasterADC -- "Workflow" --- WorkflowScheduler
    WorkflowScheduler -- "Reserve Request was Successful" --- VrmComponentManager_1 
    MasterADC -- "Atomic task" ---VrmComponentManager_1

    %% ADC_1_Internal
    ADC_1 --- VrmComponentManager_2

    %% Component Distribution
    VrmComponentManager_1 --- AcI_1
    VrmComponentManager_1 --- ADC_1
    VrmComponentManager_2 --- AcI_2
    VrmComponentManager_2 --- AcI_3

    %% AcI to RMS Mapping
    AcI_1 --- RmsConnector_1
    AcI_2 --- RmsConnector_2
    AcI_3 --- RmsConnector_3

    %% Internal RMS Links (Instance 1)
    RmsConnector_1 --- SlottedNodeSchedule_1
    RmsConnector_1 --- SlottedLinkSchedule_1
    SlottedLinkSchedule_1 --- NetworkTopology_1

    %% Internal RMS Links (Instance 2)
    RmsConnector_2 --- SlottedLinkSchedule_2
    SlottedLinkSchedule_2 --- NetworkTopology_2

    %% Internal RMS Links (Instance 3)
    RmsConnector_3 --- SlottedNodeSchedule_3

    %% Node Classes
    classDef gateNode fill:#fcfcfc,stroke:#2c3e50,stroke-width:2px;
    classDef adcParentNode fill:#fff8e1,stroke:#f39c12,stroke-width:2px,font-weight:bold;
    classDef adcChildNode fill:#fff3e0,stroke:#e67e22,stroke-width:2px,font-weight:bold;
    classDef aciNode fill:#e0f7fa,stroke:#00acc1,stroke-width:2px,font-weight:bold;
    classDef rmsNode fill:#f3e5f5,stroke:#8e44ad,stroke-width:1.5px;
    
    %% Updated Schedule Nodes to Green
    classDef scheduleNode fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,stroke-dasharray: 0;

    %% Container Styles
    style VRM_System fill:#f8f9fa,stroke:#2c3e50,stroke-width:3px,color:#2c3e50
    
    %% ADC Level (Warm Amber)
    style MasterADC_subgraph fill:#fff8e1,stroke:#f39c12,stroke-width:2px
    style ADC_subgraph_1 fill:#fff3e0,stroke:#e67e22,stroke-width:2px
    
    %% AcI Level (Cool Cyan)
    style AcI_subgraph_1 fill:#e0f7fa,stroke:#00acc1,stroke-width:1px
    style AcI_subgraph_2 fill:#e0f7fa,stroke:#00acc1,stroke-width:1px
    style AcI_subgraph_3 fill:#e0f7fa,stroke:#00acc1,stroke-width:1px

    %% RMS Level (Soft Purple)
    style Rms_AcI_1 fill:#f3e5f5,stroke:#8e44ad,stroke-width:1px
    style Rms_AcI_2 fill:#f3e5f5,stroke:#8e44ad,stroke-width:1px
    style Rms_AcI_3 fill:#f3e5f5,stroke:#8e44ad,stroke-width:1px

    %% Updated Schedule Containers (Nature/Green Gradient)
    style Schedule_1 fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style Schedule_2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style Schedule_3 fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px

    style MasterADC_subgraph font-weight:bold,font-size:25px;